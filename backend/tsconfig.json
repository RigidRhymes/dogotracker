{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "outDir": "dist",
    "rootDir": "..",   // project root
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "typeRoots": ["./node_modules/@types", "./src/types"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@/lib/*": ["../lib/*"],
      "@/database/*": ["../database/*"]
    }
  },
  "include": [
    "src/**/*",
    "../lib/**/*",
    "../database/**/*"
  ],
  "exclude": [
    "dist",
    "node_modules"
  ]
}
